{
  "openapi": "3.0.0",
  "info": {
    "title": "Local-First Collaborative Document Editor API",
    "description": "API documentation for managing documents, workspace sharing, audit logging, snapshots, and offline operational sync. Enforces cookie-based session security via NextAuth.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/api/documents": {
      "get": {
        "summary": "List Documents",
        "description": "Retrieves all documents accessible to the currently authenticated user.",
        "responses": {
          "200": {
            "description": "Successfully retrieved document list.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "documents": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "string", "format": "uuid", "example": "77777777-7777-4777-8777-777777777777" },
                          "title": { "type": "string", "example": "My Design Doc" },
                          "role": { "type": "string", "enum": ["OWNER", "EDITOR", "VIEWER"], "example": "OWNER" },
                          "createdAt": { "type": "string", "format": "date-time", "example": "2026-06-26T12:00:00.000Z" },
                          "updatedAt": { "type": "string", "format": "date-time", "example": "2026-06-26T12:30:00.000Z" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" }
        }
      },
      "post": {
        "summary": "Create Document",
        "description": "Securely creates a new document.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": { "type": "string", "minLength": 1, "maxLength": 100, "example": "New Collaborative Doc" },
                  "initialContent": { "type": "string", "description": "Base content to seed the document text state", "example": "Hello World!" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "document": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid", "example": "77777777-7777-4777-8777-777777777777" },
                        "title": { "type": "string", "example": "New Collaborative Doc" },
                        "createdAt": { "type": "string", "format": "date-time" },
                        "updatedAt": { "type": "string", "format": "date-time" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "422": { "$ref": "#/components/responses/422ValidationError" }
        }
      }
    },
    "/api/documents/{id}": {
      "get": {
        "summary": "Get Document Details",
        "description": "Securely retrieves details of a specific document.",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved document detail.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "document": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid", "example": "77777777-7777-4777-8777-777777777777" },
                        "title": { "type": "string", "example": "My Design Doc" },
                        "ownerId": { "type": "string", "format": "uuid", "example": "e8a1f802-95bd-44ef-ad79-c5c2494537dc" },
                        "createdAt": { "type": "string", "format": "date-time" },
                        "updatedAt": { "type": "string", "format": "date-time" },
                        "role": { "type": "string", "enum": ["OWNER", "EDITOR", "VIEWER"], "example": "OWNER" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "403": { "$ref": "#/components/responses/403Forbidden" },
          "404": { "$ref": "#/components/responses/404NotFound" }
        }
      },
      "patch": {
        "summary": "Rename Document",
        "description": "Securely renames/updates document title.",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": { "type": "string", "minLength": 1, "maxLength": 100, "example": "Renamed Collaborative Doc" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document renamed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "document": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid", "example": "77777777-7777-4777-8777-777777777777" },
                        "title": { "type": "string", "example": "Renamed Collaborative Doc" },
                        "updatedAt": { "type": "string", "format": "date-time" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "403": { "$ref": "#/components/responses/403Forbidden" },
          "404": { "$ref": "#/components/responses/404NotFound" },
          "422": { "$ref": "#/components/responses/422ValidationError" }
        }
      },
      "delete": {
        "summary": "Delete Document",
        "description": "Securely deletes a specific document. Owner-only.",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "description": "Document deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Document successfully deleted." }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "403": { "$ref": "#/components/responses/403Forbidden" },
          "404": { "$ref": "#/components/responses/404NotFound" }
        }
      }
    },
    "/api/documents/{id}/invite": {
      "post": {
        "summary": "Invite Collaborator",
        "description": "Invites/adds a member to a document. Owner-only.",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "role"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "collaborator@example.com" },
                  "role": { "type": "string", "enum": ["OWNER", "EDITOR", "VIEWER"], "example": "EDITOR" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Collaborator successfully invited.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Collaborator successfully invited." },
                    "membership": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid", "example": "11111111-1111-4111-8111-111111111111" },
                        "documentId": { "type": "string", "format": "uuid", "example": "77777777-7777-4777-8777-777777777777" },
                        "userId": { "type": "string", "format": "uuid", "example": "e8a1f802-95bd-44ef-ad79-c5c2494537dc" },
                        "role": { "type": "string", "enum": ["OWNER", "EDITOR", "VIEWER"], "example": "EDITOR" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "403": { "$ref": "#/components/responses/403Forbidden" },
          "422": { "$ref": "#/components/responses/422ValidationError" }
        }
      }
    },
    "/api/documents/{id}/member": {
      "patch": {
        "summary": "Change Member Role",
        "description": "Updates a document member's role. Owner-only.",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["memberId", "role"],
                "properties": {
                  "memberId": { "type": "string", "format": "uuid", "example": "11111111-1111-4111-8111-111111111111" },
                  "role": { "type": "string", "enum": ["OWNER", "EDITOR", "VIEWER"], "example": "VIEWER" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Collaborator role successfully updated.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Collaborator role successfully updated." },
                    "membership": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid", "example": "11111111-1111-4111-8111-111111111111" },
                        "documentId": { "type": "string", "format": "uuid", "example": "77777777-7777-4777-8777-777777777777" },
                        "userId": { "type": "string", "format": "uuid", "example": "e8a1f802-95bd-44ef-ad79-c5c2494537dc" },
                        "role": { "type": "string", "enum": ["OWNER", "EDITOR", "VIEWER"], "example": "VIEWER" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "403": { "$ref": "#/components/responses/403Forbidden" },
          "422": { "$ref": "#/components/responses/422ValidationError" }
        }
      },
      "delete": {
        "summary": "Remove Member",
        "description": "Removes a collaborator from a document. Owner-only.",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["memberId"],
                "properties": {
                  "memberId": { "type": "string", "format": "uuid", "example": "11111111-1111-4111-8111-111111111111" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Collaborator successfully removed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Collaborator successfully removed." }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "403": { "$ref": "#/components/responses/403Forbidden" },
          "422": { "$ref": "#/components/responses/422ValidationError" }
        }
      }
    },
    "/api/documents/{id}/snapshot": {
      "post": {
        "summary": "Create Snapshot",
        "description": "Creates a historic version snapshot for a document. Owner or Editor.",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["snapshot"],
                "properties": {
                  "snapshot": { "type": "string", "description": "Hex-encoded Yjs state document snapshot", "example": "01020304050607" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Snapshot successfully created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Snapshot version successfully created." },
                    "version": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid", "example": "00000000-0000-4000-a000-000000000001" },
                        "documentId": { "type": "string", "format": "uuid", "example": "77777777-7777-4777-8777-777777777777" },
                        "createdAt": { "type": "string", "format": "date-time" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "403": { "$ref": "#/components/responses/403Forbidden" },
          "422": { "$ref": "#/components/responses/422ValidationError" }
        }
      }
    },
    "/api/documents/{id}/history": {
      "get": {
        "summary": "Get Document Snapshot History",
        "description": "Retrieves the full list of version snapshots captured for the document. Reader, Editor, or Owner.",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved version history.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "history": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "string", "format": "uuid", "example": "00000000-0000-4000-a000-000000000001" },
                          "documentId": { "type": "string", "format": "uuid" },
                          "createdAt": { "type": "string", "format": "date-time" },
                          "creator": {
                            "type": "object",
                            "properties": {
                              "id": { "type": "string", "format": "uuid" },
                              "name": { "type": "string", "example": "Bob" },
                              "email": { "type": "string", "example": "bob@example.com" }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "403": { "$ref": "#/components/responses/403Forbidden" }
        }
      }
    },
    "/api/documents/{id}/compare": {
      "get": {
        "summary": "Compare Snapshots",
        "description": "Retrieves differences/comparisons between two historic document snapshot states.",
        "parameters": [
          { "$ref": "#/components/parameters/id" },
          {
            "name": "versionA",
            "in": "query",
            "required": true,
            "description": "The first snapshot version UUID",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "versionB",
            "in": "query",
            "required": true,
            "description": "The second snapshot version UUID",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully compared snapshot text states.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "comparison": {
                      "type": "object",
                      "properties": {
                        "contentA": { "type": "string", "example": "Hello" },
                        "contentB": { "type": "string", "example": "Hello World!" },
                        "areIdentical": { "type": "boolean", "example": false }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "403": { "$ref": "#/components/responses/403Forbidden" },
          "422": { "$ref": "#/components/responses/422ValidationError" }
        }
      }
    },
    "/api/documents/{id}/restore": {
      "post": {
        "summary": "Restore Snapshot",
        "description": "Restores the document state to match a target historic snapshot. Editor or Owner.",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["versionId"],
                "properties": {
                  "versionId": { "type": "string", "format": "uuid", "example": "00000000-0000-4000-a000-000000000001" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document successfully restored.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Document successfully restored to the target snapshot state." },
                    "result": {
                      "type": "object",
                      "properties": {
                        "success": { "type": "boolean", "example": true },
                        "version": { "type": "integer", "example": 6 }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "403": { "$ref": "#/components/responses/403Forbidden" },
          "422": { "$ref": "#/components/responses/422ValidationError" }
        }
      }
    },
    "/api/documents/{id}/audit": {
      "get": {
        "summary": "Get Document Audit Log",
        "description": "Retrieves the full audit log history of document creation, deletion, role modification, snapshotting, and synchronization errors. Owner-only.",
        "parameters": [
          { "$ref": "#/components/parameters/id" },
          {
            "name": "action",
            "in": "query",
            "required": false,
            "description": "Filter audit logs by specific AuditAction code",
            "schema": {
              "type": "string",
              "enum": ["DOCUMENT_CREATED", "DOCUMENT_DELETED", "ROLE_CHANGED", "SNAPSHOT_CREATED", "RESTORE_PERFORMED", "SYNC_FAILED"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved audit logs.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "logs": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "string", "format": "uuid" },
                          "action": { "type": "string", "enum": ["DOCUMENT_CREATED", "DOCUMENT_DELETED", "ROLE_CHANGED", "SNAPSHOT_CREATED", "RESTORE_PERFORMED", "SYNC_FAILED"] },
                          "userId": { "type": "string", "format": "uuid" },
                          "documentId": { "type": "string", "format": "uuid" },
                          "metadata": { "type": "object", "nullable": true },
                          "createdAt": { "type": "string", "format": "date-time" },
                          "user": {
                            "type": "object",
                            "properties": {
                              "id": { "type": "string", "format": "uuid" },
                              "name": { "type": "string", "example": "Alice" },
                              "email": { "type": "string", "example": "alice@example.com" }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "403": { "$ref": "#/components/responses/403Forbidden" }
        }
      }
    },
    "/api/sync": {
      "post": {
        "summary": "Synchronize Operations",
        "description": "Securely uploads a batch of client operations to synchronize changes across offline document instances.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["documentId", "clientId", "operations"],
                "properties": {
                  "documentId": { "type": "string", "format": "uuid", "example": "c77d4e88-4f7d-4f7c-8ead-b526ad47a180" },
                  "clientId": { "type": "string", "minLength": 1, "example": "client-instance-bob" },
                  "operations": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 100,
                    "items": {
                      "type": "object",
                      "required": ["version", "change"],
                      "properties": {
                        "version": { "type": "integer", "minimum": 1, "example": 3 },
                        "change": { "type": "string", "description": "Hex-encoded operation block payload", "example": "0a2cde" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Operations successfully synchronized.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Operations successfully synchronized." }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "403": { "$ref": "#/components/responses/403Forbidden" },
          "409": {
            "description": "Version Conflict. Client must fetch changes and rebase.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": false },
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": { "type": "string", "example": "VERSION_CONFLICT" },
                        "message": { "type": "string", "example": "Version conflict detected. Latest server version is 2. Please rebase." },
                        "details": {
                          "type": "object",
                          "properties": {
                            "latestVersion": { "type": "integer", "example": 2 }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "422": { "$ref": "#/components/responses/422ValidationError" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "id": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "The unique UUID of the document",
        "schema": { "type": "string", "format": "uuid" }
      }
    },
    "responses": {
      "401Unauthorized": {
        "description": "Request has expired token or is unauthenticated.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": false },
                "error": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "string", "example": "UNAUTHORIZED" },
                    "message": { "type": "string", "example": "You must be signed in to access this resource." }
                  }
                }
              }
            }
          }
        }
      },
      "403Forbidden": {
        "description": "User has read access but does not possess required role permissions (e.g. editor or owner).",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": false },
                "error": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "string", "example": "FORBIDDEN" },
                    "message": { "type": "string", "example": "You do not have the required access permissions on this document." }
                  }
                }
              }
            }
          }
        }
      },
      "404NotFound": {
        "description": "Target document does not exist, or current user is not a member (preventing ID exposure).",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": false },
                "error": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "string", "example": "NOT_FOUND" },
                    "message": { "type": "string", "example": "Document not found" }
