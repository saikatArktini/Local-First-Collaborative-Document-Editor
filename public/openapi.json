                }
              }
            }
          }
        }
      },
      "422ValidationError": {
        "description": "Zod Schema validation failed for request payload.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": false },
                "error": {
                  "type": "object",
